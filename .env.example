FUBON_PERSON_ID=
FUBON_API_KEY=
FUBON_LOGIN_PASSWORD=
FUBON_CERT_PATH=
FUBON_CERT_PASSWORD=
FUBON_ACCOUNT_INDEX=0
FUBON_DRY_RUN=true

# Maximum capital this strategy is allowed to control. Keep explicit even when
# broker bank_remain is available; the bot must not assume all account cash is
# strategy capital.
QL_STRATEGY_CAPITAL_TWD=50000
QL_CASH_BUFFER_PCT=0.03
QL_CASH_BUFFER_TWD=0

# Default uses buy LimitUp / sell LimitDown orders submitted next-session so the
# order is marketable but still bounded by the daily price limit.
QL_ORDER_PRICE_POLICY=limit_up_down
QL_BUY_PRICE_BUFFER_PCT=0.10
QL_MIN_ORDER_NOTIONAL_TWD=0
QL_MANAGED_POSITIONS_PATH=research/state/trading/managed_positions.json
QL_PLANS_DIR=research/out/trading/plans

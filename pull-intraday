#!/bin/bash
# 每日日內資料回補(1 分 K)——直接執行本檔即可,不需要任何參數。
#
#   ./pull-intraday          # 續傳回補(用滿今日額度就自動停)
#   ./pull-intraday --status # 只看進度,不連線、不吃額度
#
# 設計:
# - 進度存在磁碟檔案本身,**隨時 Ctrl-C 或關機都能續傳**,最多重做當下那一格。
# - 額度用完(永豐每日 2GB,交易日 08:00 重置)會自己停,不會報錯。
# - 每天跑一次即可;跑多久取決於當日剩餘額度,通常數分鐘到半小時。
set -euo pipefail
cd "$(dirname "$0")"
exec uv run --project research python -m research.intraday.pull_kbars "$@" 2>&1 \
  | grep -vE "Response Code|Event Code|Session up|DeprecationWarning|api = _login|^$"
